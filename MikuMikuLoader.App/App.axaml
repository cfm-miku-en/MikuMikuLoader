<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MikuMikuLoader.App.ViewModels"
             xmlns:views="clr-namespace:MikuMikuLoader.App.Views"
             x:Class="MikuMikuLoader.App.App"
             RequestedThemeVariant="Dark">

  <Application.DataTemplates>
    <DataTemplate DataType="vm:BrowseViewModel"><views:BrowseView /></DataTemplate>
    <DataTemplate DataType="vm:LibraryViewModel"><views:LibraryView /></DataTemplate>
    <DataTemplate DataType="vm:SettingsViewModel"><views:SettingsView /></DataTemplate>
    <DataTemplate DataType="vm:DevPanelViewModel"><views:DevPanelView /></DataTemplate>
    <DataTemplate DataType="vm:LoginViewModel"><views:LoginView /></DataTemplate>
    <DataTemplate DataType="vm:ModDetailViewModel"><views:ModDetailView /></DataTemplate>
    <DataTemplate DataType="vm:NewsViewModel"><views:NewsView /></DataTemplate>
  </Application.DataTemplates>

  <Application.Resources>
    <ResourceDictionary>
      <Color x:Key="AccentColor">#F2A03D</Color>
      <SolidColorBrush x:Key="AccentBrush" Color="#F2A03D" />
      <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFB258" />
      <SolidColorBrush x:Key="AccentDimBrush" Color="#3A2E1B" />

      <SolidColorBrush x:Key="BgBrush" Color="#0F1012" />
      <SolidColorBrush x:Key="PanelBrush" Color="#141518" />
      <SolidColorBrush x:Key="PanelAltBrush" Color="#202127" />
      <SolidColorBrush x:Key="CardBrush" Color="#17181C" />
      <SolidColorBrush x:Key="CardHoverBrush" Color="#1D1F24" />
      <SolidColorBrush x:Key="BorderSoftBrush" Color="#24262B" />

      <SolidColorBrush x:Key="TextBrush" Color="#ECEDEF" />
      <SolidColorBrush x:Key="MutedBrush" Color="#8A8D94" />
      <SolidColorBrush x:Key="DangerBrush" Color="#C4312A" />

      <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Menlo, monospace</FontFamily>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
    </Style>

    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="27" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="TextBlock.sub">
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
    </Style>

    <Style Selector="Border.segment">
      <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
    </Style>

    <Style Selector="Button.tab">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.tab:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="Button.tab.active">
      <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.nav">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.nav:pointerover">
      <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="Button.nav.active">
      <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style Selector="Button.win">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="CornerRadius" Value="15" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.win:pointerover">
      <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="Button.win.close:pointerover">
      <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="#20160A" />
      <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.accent:pointerover">
      <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.accent:disabled">
      <Setter Property="Opacity" Value="0.45" />
    </Style>

    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
    </Style>
    <Style Selector="Button.ghost:pointerover">
      <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
    </Style>
    <Style Selector="Button.ghost:disabled">
      <Setter Property="Opacity" Value="0.45" />
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="13" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style Selector="Border.chip">
      <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="9,3" />
      <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style Selector="Button.chip">
      <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
      <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="11,4" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.chip:pointerover">
      <Setter Property="Background" Value="{DynamicResource BorderSoftBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="12,9" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="ToggleButton">
      <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="14,9" />
    </Style>
    <Style Selector="ToggleButton:checked">
      <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
  </Application.Styles>
</Application>
