<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MikuMikuLoader.App.ViewModels"
             x:Class="MikuMikuLoader.App.Views.LibraryView">

  <Grid RowDefinitions="Auto,*" Background="{DynamicResource BgBrush}">

    <Border Grid.Row="0" Classes="card" Margin="26,0,26,12">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
        <TextBlock Grid.Column="0" Text="{Binding GameFolderStatus}" TextWrapping="Wrap"
                   Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" FontSize="12.5" />
        <Button Grid.Column="1" Classes="accent" Content="Launch game"
                Command="{Binding LaunchGameCommand}" Margin="12,0,0,0" />
        <Button Grid.Column="2" Classes="ghost" Content="Rescan"
                Command="{Binding RefreshingCommand}" Margin="8,0,0,0" />
        <Button Grid.Column="3" Classes="ghost" Content="Detect"
                Command="{Binding DetectGameCommand}" Margin="8,0,0,0" />
        <Button Grid.Column="4" Classes="ghost" Content="Open folder"
                Command="{Binding OpenPluginsCommand}" IsEnabled="{Binding HasGameFolder}"
                Margin="8,0,0,0" />
      </Grid>
    </Border>

    <Panel Grid.Row="1">
      <ScrollViewer Padding="26,0,26,18">
        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:LibraryItemViewModel">
              <Border Classes="card">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"
                                 VerticalAlignment="Center" />
                      <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="4"
                              Padding="8,2" VerticalAlignment="Center" IsVisible="{Binding !Enabled}">
                        <TextBlock Text="disabled" FontSize="10" Foreground="{DynamicResource MutedBrush}" />
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                  </StackPanel>
                  <Button Grid.Column="1" Classes="ghost" Content="{Binding ToggleText}"
                          Command="{Binding ToggleCommand}" IsVisible="{Binding CanToggle}"
                          VerticalAlignment="Center" Margin="0,0,8,0" />
                  <Button Grid.Column="2" Classes="ghost" Content="Delete"
                          Command="{Binding DeleteCommand}" VerticalAlignment="Center" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <StackPanel IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center"
                  VerticalAlignment="Center" Spacing="6" MaxWidth="440">
        <TextBlock Text="No mods in your plugins folder." HorizontalAlignment="Center"
                   Foreground="{DynamicResource TextBrush}" FontSize="15" FontWeight="Bold" />
        <TextBlock Text="Install mods from Browse Online, or drop DLLs into BepInEx/plugins and hit Rescan. Anything already in there shows up here too."
                   Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" TextAlignment="Center" />
      </StackPanel>
    </Panel>
  </Grid>
</UserControl>
