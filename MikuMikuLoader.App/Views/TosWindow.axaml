<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MikuMikuLoader.App.Views.TosWindow"
        Title="MikuMikuLoader - Terms"
        Width="620" Height="560"
        MinWidth="480" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        CanResize="True">

  <Grid RowDefinitions="Auto,*,Auto" Margin="20">
    <TextBlock Grid.Row="0" Text="Before you continue" FontSize="18" FontWeight="Bold"
               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12" />

    <Border Grid.Row="1" Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1"
            CornerRadius="13" Padding="14">
      <ScrollViewer>
        <TextBlock x:Name="TosText" TextWrapping="Wrap" Foreground="#C4C7CD" FontSize="12.5" />
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="10" Margin="0,14,0,0">
      <Button Classes="ghost" Content="Decline &amp; quit" Click="OnDecline" />
      <Button Classes="accent" Content="I agree" Click="OnAgree" />
    </StackPanel>
  </Grid>
</Window>
