<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MikuMikuLoader.App.ViewModels"
             x:Class="MikuMikuLoader.App.Views.SettingsView">

  <ScrollViewer Background="{DynamicResource BgBrush}">
    <StackPanel Margin="20" Spacing="14" MaxWidth="640" HorizontalAlignment="Left">

      <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" />

      <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderSoftBrush}"
              BorderThickness="1" CornerRadius="13" Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="Mod server" FontWeight="Bold" />
          <TextBlock Text="The loader points at this server for Browse Online. Change it to use a different community server."
                     Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" FontSize="12.5" />

          <TextBox Text="{Binding ServerUrl}" Watermark="http://localhost:5279"
                   VerticalContentAlignment="Center" />

          <TextBlock Text="{Binding DefaultHint}" Foreground="{DynamicResource MutedBrush}" FontSize="11" />

          <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
            <Button Classes="accent" Content="Save &amp; connect" Command="{Binding SaveCommand}" />
            <Button Classes="ghost" Content="Reset to default" Command="{Binding ResetToDefaultCommand}" />
          </StackPanel>

          <TextBlock Text="{Binding Status}" Foreground="{DynamicResource AccentBrush}"
                     FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" />
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderSoftBrush}"
              BorderThickness="1" CornerRadius="13" Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="Gorilla Tag folder" FontWeight="Bold" />
          <TextBlock Text="Where mods get installed (into BepInEx/plugins). Auto-detect finds it through Steam, or point it at the folder yourself."
                     Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" FontSize="12.5" />

          <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="6" Padding="10,7">
            <TextBlock Text="{Binding GameFolder}" Foreground="{DynamicResource TextBrush}"
                       FontSize="12" TextWrapping="Wrap" />
          </Border>

          <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
            <Button Classes="accent" Content="Auto-detect" Command="{Binding DetectGameCommand}" />
            <Button Classes="ghost" Content="Browse…" Click="OnBrowseFolder" />
          </StackPanel>

          <TextBlock Text="{Binding GameFolderStatus}" Foreground="{DynamicResource AccentBrush}"
                     FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
